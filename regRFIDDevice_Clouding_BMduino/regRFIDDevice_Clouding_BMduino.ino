/*-------------------------------------------------------------
  程式名稱：RFID 門禁裝置雲端註冊程式 (regRFIDDevice_Clouding_BMduino)
  程式用途：本程式用於將 RFID 門禁裝置註冊至雲端伺服器，
           透過 WiFi 連線取得裝置的 SSID、IP 位址、MAC 位址等資訊，
           並將這些資訊上傳至雲端進行裝置註冊與管理。
  
  硬體架構：適用於 BMduino 開發板，搭配 BMC81M001 WiFi 模組進行無線網路連線，
           支援 TCP/IP 通訊協定與 HTTP GET 請求。
  
  作者說明：本程式為 Arduino C 語言撰寫，主要功能為：
           1. 初始化 WiFi 連線至指定的無線基地台
           2. 取得並顯示連線狀態、SSID、IP 位址、MAC 位址
           3. 將裝置資訊透過 HTTP GET 請求傳送至雲端伺服器進行註冊
           4. 可依需求擴充為定期回報或斷線重連機制
  
  主要功能流程：
    1. 開機初始化（setup）：
       - 熄滅 LED 指示燈
       - 啟動序列埠監控（9600 bps）
       - 初始化 WiFi 連線
       - 顯示連線的 SSID、IP 位址、MAC 位址
       - 產生隨機種子（用於後續隨機數生成）
       - 檢查 WiFi 連線狀態，若正常則執行雲端註冊
    2. 主迴圈（loop）：
       - 目前為註解狀態，可依需求啟用定期註冊或斷線重連功能
  
  最後修改：2026年
  版本：V1.0
-------------------------------------------------------------*/

// 註冊 RFID 裝置之雲端門禁裝置  regRFIDDevice_Clouding_BMduino
#include <String.h>           // 引入字串處理函式庫，用於字串操作
#include "TCP.h"              // 引入 TCP 控制邏輯相關函式與變數定義
                              // 此檔案應包含 WiFi 初始化、連線管理、MAC 位址取得等功能
#include "clouding.h"         // 引入雲端通訊函式庫
                              // 此檔案應包含 HTTP GET 請求、資料上傳至雲端等功能

/*-------------------------------------------------------------
  函式名稱：setup
  功能說明：Arduino 初始化函式，在開機或重置時執行一次
  輸入參數：無
  回傳值：無
  執行內容：
    1. 初始化 LED 狀態（熄滅）
    2. 啟動序列埠通訊，作為監控輸出
    3. 初始化 WiFi 連線
    4. 顯示連線資訊（SSID、IP 位址、MAC 位址）
    5. 產生隨機種子
    6. 檢查 WiFi 狀態並執行雲端註冊
-------------------------------------------------------------*/
void setup() 
{
  digitalWrite(LED, LOW);      // 將 LED 腳位設定為 LOW（熄滅）
                               // 可視為開機狀態指示，表示系統已啟動但尚未進行雲端註冊
                               // LED 腳位應在 TCP.h 或相關標頭檔中定義

  Serial.begin(9600);          // 啟動主機序列埠（USB）通訊，速率為 9600 bps
                               // 用於輸出監控資訊至 Arduino IDE 的序列埠監控視窗

  initWiFi();                  // 執行 WiFi 模組初始化與連線
                               // 此函式定義於 TCP.h / BMC81M001.h 中
                               // 功能：設定工作站模式、連線至指定的無線基地台

  Serial.println("");          // 印出空行，純粹格式美觀，便於閱讀監控輸出
  Serial.println("---wifi access point----"); // 分隔線，標示 WiFi 資訊區塊開始
  Serial.println(GetSSID());   // 取得並印出目前連線的 SSID（無線基地台名稱）
                               // GetSSID() 函式應定義於 TCP.h 中
  
  // Serial.println(typeof(Wifi.SSID())) ; // 註解掉的除錯語句，用於查資料型別
                                           // 保留作為開發時的參考

  Serial.println("---Show IP Address----"); // 分隔線，標示 IP 位址資訊區塊開始
  Serial.println(GetIP());     // 取得並印出裝置的 IP 位址
                               // GetIP() 函式應定義於 TCP.h 中
                               // 此 IP 位址為 WiFi 基地台分配的區域網路位址

  MacData = GetMAC();          // 取得 MAC 位址字串並儲存至全域變數 MacData
                               // GetMAC() 函式應定義於 TCP.h 中
                               // MAC 位址為裝置的唯一硬體識別碼，用於雲端註冊識別

  Serial.println("---MAC Address----"); // 分隔線，標示 MAC 位址資訊區塊開始
  Serial.println(MacData);     // 印出裝置的 MAC 位址，便於後續追蹤與除錯

  randomSeed(analogRead(A0));  // 使用類比腳位 A0 的雜訊產生隨機種子
                               // A0 腳位若未連接任何訊號，會讀取到環境雜訊
                               // 此種子用於後續需要隨機數的場合（如產生隨機延遲、Client ID 等）

  // 檢查 WiFi 連線狀態，若連線正常則執行雲端註冊
  if (Wifi.getStatus())        // getStatus() 應回傳 WiFi 連線狀態（非 0 表示已連線）
  {
    Serial.println("WIFI OK"); // 輸出連線成功訊息至序列埠監控視窗
    SendtoClouding();          // 傳送裝置資料到雲端伺服器進行註冊
                               // SendtoClouding() 函式定義於 clouding.h 中
                               // 通常會將 MAC 位址、裝置類型等資訊透過 HTTP GET 上傳
  }
}

/*-------------------------------------------------------------
  函式名稱：loop
  功能說明：Arduino 主迴圈，在 setup() 執行後重複執行
  輸入參數：無
  回傳值：無
  執行內容：
    目前此函式內程式碼皆為註解狀態，表示未啟用任何週期性功能
  
  可選功能說明（註解區塊內）：
    1. 定期檢查 WiFi 連線狀態，若斷線則重新連線
    2. 定期向雲端伺服器註冊或回報裝置狀態
    3. 使用 delay(120000) 可設定每 2 分鐘執行一次雲端註冊
  
  註解區塊功能說明：
    - 若啟用註解區塊，程式會每 120 秒（2 分鐘）檢查一次 WiFi 狀態
    - 若 WiFi 正常，直接執行雲端註冊
    - 若 WiFi 異常，則重新初始化 WiFi 連線，重新取得 MAC 位址後再執行雲端註冊
-------------------------------------------------------------*/
void loop() 
{
 
}